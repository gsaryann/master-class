APP_NAME="Master Class CI"
APP_ENV=testing
APP_DEBUG=false
APP_URL=http://localhost
APP_KEY=
# APP_KEY может быть пустым в шаблоне; пайплайн генерирует его перед тестами.

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=:memory:
DB_USERNAME=
DB_PASSWORD=

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
BCRYPT_ROUNDS=4
